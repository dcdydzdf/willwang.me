---
import BaseLayout from "../layouts/BaseLayout.astro";

const sections = [
  {
    title: "Industry",
    href: "/industry",
    description: "Analysis of markets, technology, and the systems shaping modern work.",
    icon: "industry",
  },
  {
    title: "Literature",
    href: "/literature",
    description: "Reading notes and essays on books, language, and enduring ideas.",
    icon: "literature",
  },
  {
    title: "Reflections",
    href: "/reflections",
    description: "Personal observations on attention, growth, and a considered life.",
    icon: "reflections",
  },
];
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Writing and Perspective</span>
      <h1>Will Wang</h1>
      <p class="hero-copy">
        Thoughts on industry, literature, and the quiet practice of reflection.
      </p>
    </div>
  </section>
  <section class="container sections-grid" aria-label="Writing sections">
    {
      sections.map((section) => (
        <a class="section-card" href={section.href}>
          <span class="card-mark" aria-hidden="true">
            {section.icon === "industry" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.45">
                <path d="M4 19V9l5 3V7l6 4V5l5 3v11H4Z" />
                <path d="M8 19v-3m4 3v-3m4 3v-3" />
              </svg>
            )}
            {section.icon === "literature" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.45">
                <path d="M4.5 5.5c2.8-1.1 5.3-.8 7.5 1.1 2.2-1.9 4.7-2.2 7.5-1.1v13c-2.8-1.1-5.3-.7-7.5 1.2-2.2-1.9-4.7-2.3-7.5-1.2v-13Z" />
                <path d="M12 6.6v13.1" />
              </svg>
            )}
            {section.icon === "reflections" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.45">
                <path d="M12 3.5a8.5 8.5 0 1 0 8.5 8.5" />
                <path d="M12 7a5 5 0 1 0 5 5" />
                <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none" />
              </svg>
            )}
          </span>
          <h2>{section.title}</h2>
          <p>{section.description}</p>
        </a>
      ))
    }
  </section>
</BaseLayout>
